generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  username  String
  documents Document[] 
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  title     String
  content   Bytes?
  ownerId   String?    
  owner     User?      @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}